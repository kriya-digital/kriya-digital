    <!-- Middle Section: Hubs -->
    <div class="flex flex-col gap-4 md:w-1/4">
      <h3 class="font-body-lg text-white font-bold mb-2">Kriya Hubs</h3>
      <a href="/solutions" class="text-on-surface-variant hover:text-white transition-colors text-sm font-body-lg w-max">Solutions Ecosystem</a>
      <a href="/casestudies" class="text-on-surface-variant hover:text-white transition-colors text-sm font-body-lg w-max">Case Studies</a>
      <a href="/contact" class="text-on-surface-variant hover:text-white transition-colors text-sm font-body-lg w-max">Contact Us</a>
    </div>

    <!-- Right Section: Legal -->
    <div class="flex flex-col gap-4 md:w-1/4">
      <h3 class="font-body-lg text-white font-bold mb-2">Kriya Legal</h3>
      <a href="/corporate/dpa" class="text-on-surface-variant hover:text-white transition-colors text-sm font-body-lg w-max">Terms & Conditions</a>
      <a href="/corporate/privacy-notice" class="text-on-surface-variant hover:text-white transition-colors text-sm font-body-lg w-max">Privacy Notice</a>
      <a href="/corporate/grievance-redressal" class="text-on-surface-variant hover:text-white transition-colors text-sm font-body-lg w-max">Refund & Cancellation</a>
    </div>

    <!-- Right Section 2: Contact -->
    <div class="flex flex-col gap-4 md:w-1/4">
      <h3 class="font-body-lg text-white font-bold mb-2">Connect</h3>
      <a href="/contact" class="text-on-surface-variant hover:text-white transition-colors text-sm font-body-lg w-max">Contact Portal</a>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto px-8 mt-16 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="font-body-lg text-xs text-on-surface-variant">© 2026 Kriya Digital Platform. All rights reserved.</p>
