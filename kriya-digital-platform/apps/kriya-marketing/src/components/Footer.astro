---
---
<footer class="w-full py-16 bg-[#0e0e0e] border-t border-white/10 mt-20">
  <div class="px-8 max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-12 md:gap-8">
    
    <!-- Left Section -->
    <div class="flex flex-col gap-6 md:w-1/4">
      <div class="flex flex-col gap-1">
        <a href="/" class="block cursor-pointer w-max">
          <img src="/logos/kriya-white.png" alt="Kriya" class="h-10 w-auto" />
        </a>
        <span class="font-body-lg text-sm text-on-surface-variant mt-2">Everything web. we do.</span>
      </div>
      
      <div class="mt-4">
        <p class="font-body-lg text-sm text-white font-bold mb-4">Follow us</p>
        <div class="flex gap-3">
          <!-- X (Twitter) -->
          <a href="https://x.com/kriyaggu" target="_blank" rel="noopener noreferrer" class="w-10 h-10 flex items-center justify-center bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-electric-sulfur/50 transition-colors group">
            <svg class="w-4 h-4 text-white group-hover:text-electric-sulfur transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 24.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
