---
import Layout from '../layouts/Layout.astro';
import DesktopNav from '../components/DesktopNav.astro';
import MobileCanvas from '../components/MobileCanvas.tsx';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | Kriya">
  <!-- Desktop Layout -->
  <div class="hidden md:block">
    <DesktopNav />
    
    <main class="pt-32 pb-24 px-6 max-w-7xl mx-auto min-h-screen flex items-center justify-center">
      <div class="w-full max-w-2xl bg-[#131313]/5 backdrop-blur-md border border-white/10 rounded-[24px] p-12 text-center">
        <h1 class="font-headline-lg text-4xl text-white mb-6">Get in Touch</h1>
        <p class="font-body-lg text-on-surface-variant text-lg mb-8">
          Connect with us instantly via WhatsApp or reach out through email or phone for any queries. We're ready to engineer your next digital platform.
        </p>

        <div class="flex flex-col gap-4 mb-8 text-left max-w-sm mx-auto">
          <div class="flex flex-col gap-2">
            <label for="wa-name" class="font-label-sm text-xs text-electric-sulfur uppercase tracking-widest">Name</label>
            <input type="text" id="wa-name" placeholder="Your Name" class="bg-[#131313]/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-electric-sulfur transition-colors font-body-lg placeholder-white/30" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="wa-service" class="font-label-sm text-xs text-electric-sulfur uppercase tracking-widest">Service of Interest</label>
            <div class="relative">
              <select id="wa-service" class="w-full bg-[#131313]/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-electric-sulfur transition-colors font-body-lg appearance-none cursor-pointer">
                <option value="General Inquiry" class="bg-[#131313] text-white">General Inquiry</option>
                <option value="Web Engineering" class="bg-[#131313] text-white">Web Engineering (Build)</option>
                <option value="App Development" class="bg-[#131313] text-white">App Development (Build)</option>
                <option value="UI/UX Design" class="bg-[#131313] text-white">UI/UX Design (Build)</option>
                <option value="Growth & SEO" class="bg-[#131313] text-white">Growth & SEO (Scale)</option>
                <option value="AI Automation" class="bg-[#131313] text-white">AI Automation (Automate)</option>
              </select>
              <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-white/50 pointer-events-none">expand_more</span>
            </div>
          </div>
        </div>
        
        <button id="wa-button" class="inline-flex items-center justify-center gap-2 w-full max-w-sm bg-[#25D366] text-white px-8 py-4 rounded-xl font-headline-md text-lg font-bold hover:shadow-[0_0_30px_rgba(37,211,102,0.3)] transition-all active:scale-95 mb-12">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Chat on WhatsApp
        </button>

        <div class="border-t border-white/10 pt-8 mt-4 grid grid-cols-1 sm:grid-cols-2 gap-6 text-left">
          <div class="flex flex-col gap-2">
            <h3 class="font-body-lg text-sm text-electric-sulfur uppercase tracking-widest">Email</h3>
            <a href="mailto:kriyaggu@gmail.com" class="font-headline-md text-white text-lg hover:text-electric-sulfur transition-colors flex items-center gap-2">
              <span class="material-symbols-outlined text-[20px]">mail</span>
              kriyaggu@gmail.com
            </a>
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="font-body-lg text-sm text-electric-sulfur uppercase tracking-widest">Phone</h3>
            <a href="tel:+919202553587" class="font-headline-md text-white text-lg hover:text-electric-sulfur transition-colors flex items-center gap-2">
              <span class="material-symbols-outlined text-[20px]">phone</span>
              +91 9202553587
            </a>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>

  <!-- Mobile Layout -->
  <MobileCanvas client:load />

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const waButton = document.getElementById('wa-button');
    const nameInput = document.getElementById('wa-name') as HTMLInputElement;
    const serviceSelect = document.getElementById('wa-service') as HTMLSelectElement;

    if (waButton) {
      waButton.addEventListener('click', () => {
        const name = nameInput.value.trim() || 'There';
        const service = serviceSelect.value;
        const text = `Hi Kriya Team! I'm ${name}. I'm interested in discussing ${service}.`;
        const waUrl = `https://wa.me/919202553587?text=${encodeURIComponent(text)}`;
        window.open(waUrl, '_blank');
      });
    }
  });
</script>
