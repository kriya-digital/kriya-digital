---
import Layout from '../../layouts/Layout.astro';
import DesktopNav from '../../components/DesktopNav.astro';
import MobileCanvas from '../../components/MobileCanvas.tsx';
import Footer from '../../components/Footer.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SliderWrapper from '../../components/SliderWrapper.astro';

import openaiLogo from '../../assets/openai.svg';
import whatsappLogo from '../../assets/whatsapp.svg';
// HMR trigger
---

<Layout title="Kriya | AI (Automate)">
  <div class="hidden md:block">
    <DesktopNav />
    
    <div class="px-6 max-w-7xl mx-auto pt-32 pb-24">
      <!-- Hero Section -->
      <section class="text-center mb-24">
        <h1 class="font-headline-lg text-white text-5xl lg:text-[88px] tracking-tight leading-[1] mb-6">
          Intelligence. Automation. Workflows.
        </h1>
        <p class="text-on-surface-variant text-xl font-body-lg max-w-3xl mx-auto">
          Custom neural frameworks and machine learning models integrated directly into your business logic. We automate the future.
        </p>
      </section>

      <!-- The Grid -->
      <div class="mb-32">
        <SliderWrapper>
          <div class="snap-start shrink-0 w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)]">
            <ServiceCard 
              title="Automation Solution" 
              techStack="Machine Learning • Process Automation • Systems Integration" 
              imageContent={openaiLogo}
              altText="Automation Solution Logo"
              logoMode={true}
            />
          </div>
          <div class="snap-start shrink-0 w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.333rem)]">
            <ServiceCard 
              title="WhatsApp Automation" 
              techStack="Chatbots • Workflow Integration • CRM Setup" 
              imageContent={whatsappLogo}
              altText="WhatsApp Automation Logo"
              logoMode={true}
            />
          </div>
        </SliderWrapper>
      </div>

      <!-- WhatsApp CTA -->
      <section class="bg-electric-sulfur rounded-[32px] p-16 text-center flex flex-col items-center justify-center shadow-[0_0_100px_rgba(252,253,149,0.15)] relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
        <h2 class="font-headline-md text-4xl lg:text-5xl text-black mb-10 relative z-10 leading-tight">
          Ready to automate?<br/>Chat directly with our AI team.
        </h2>
        <a 
          href="/contact" 
          class="relative z-10 inline-flex items-center gap-3 bg-black text-electric-sulfur px-10 py-5 rounded-full font-headline-md text-xl font-bold hover:scale-105 hover:shadow-2xl transition-all active:scale-95"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          Get in Touch
        </a>
      </section>
    </div>
    
    <Footer />
  </div>

  <MobileCanvas client:load />
</Layout>
