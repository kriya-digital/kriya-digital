---
import Layout from '../../../layouts/Layout.astro';
import DesktopNav from '../../../components/DesktopNav.astro';
---
<Layout title="Privacy Notice | Kriya">
  <DesktopNav />
  <main class="pt-32 pb-24 px-6 max-w-4xl mx-auto">
    <h1 class="font-headline-lg text-4xl mb-8">Dynamic Privacy Notice</h1>
    <div class="bg-[#131313]/5 backdrop-blur-md border border-white/10 rounded-2xl p-8">
      <p class="text-on-surface-variant">DPDP Act Compliance: Your data privacy and protection information.</p>
      <!-- Dynamic content from Sanity will be injected here -->
    </div>
  </main>
</Layout>
