---
import Layout from '../layouts/Layout.astro';
import DesktopNav from '../components/DesktopNav.astro';
import BentoGrid from '../components/BentoGrid.astro';
import MobileCanvas from '../components/MobileCanvas.tsx';
import Footer from '../components/Footer.astro';
// HMR trigger comments
---

<Layout title="Kriya | Everything web. we do.">
  <!-- Desktop Layout (Hidden on Mobile) -->
  <div class="hidden md:block">
    <DesktopNav />
    <BentoGrid />
    
    <Footer />
  </div>

  <!-- Mobile Layout (Hidden on Desktop) -->
  <MobileCanvas client:load />

</Layout>

<script>
  // Simple scroll reveal for desktop elements
  const observerOptions = { threshold: 0.1 };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-5');
        entry.target.classList.add('opacity-100', 'translate-y-0');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.glass-effect, [class*="bg-[#131313]/5"]').forEach(el => {
    el.classList.add('opacity-0', 'translate-y-5', 'transition-all', 'duration-700', 'ease-out');
    observer.observe(el);
  });
</script>
